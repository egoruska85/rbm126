<!DOCTYPE html>
<html>
  <head>
    <%= display_meta_tags title: @page_title, description: @page_description, keywords: @page_keywords %>
    <%= favicon_link_tag '/images/logo_0.png' %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script src="https://api-maps.yandex.ru" type="text/javascript"></script>

    <link href="https://cdn.jsdelivr.net/npm/lightbox2@2/dist/css/lightbox.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/lightbox2@2/dist/js/lightbox.min.js"></script>

    <style media="screen">
      html, body {
        height: 100%;
        margin: 0;
      }

      .wrapper {
        min-height: 84.6vh;       /* вся высота экрана */
        display: flex;
        flex-direction: column;
      }

      .content {
        flex: 1;                /* занимает всё свободное место */
      }

      .footer {
        background: #333;
        color: white;
        padding: 20px;
      }
    </style>

<!-- Yandex.Metrika counter -->

<script type="text/javascript">
    (function(m,e,t,r,i,k,a){
        m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
        m[i].l=1*new Date();
        for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
        k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
    })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=108687898', 'ym');

    ym(108687898, 'init', {ssr:true, webvisor:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true});
</script>
<noscript><div><img src="https://mc.yandex.ru/watch/108687898" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
<!-- /Yandex.Metrika counter -->


  </head>

  <body>
    <div id="flash-notifications" class="flash-container">
      <% flash.each do |type, message| %>
        <% alert_class = type == 'notice' ? 'success' : 'danger' %>
        <% icon_class = type == 'notice' ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill' %>

        <div class="alert alert-<%= alert_class %> alert-dismissible fade show shadow shadow-lg mb-3 custom-alert" role="alert">
          <div class="d-flex align-items-center">
            <i class="bi <%= icon_class %> me-2"></i>
            <div><%= message %></div>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>
    </div>
    <div class="wrapper">
      <main class="content">
    <%= yield %>
        </main>
      </div>
      <section id="contacts" class="section py-5 bg-dark text-white">
  <div class="container text-center">
    <h2 class="section-title text-white mb-5">КОНТАКТЫ</h2>

    <div class="row g-4 justify-content-center">
      <%# Телефон %>
      <div class="col-12 col-md-4">
        <div class="p-3">
          <div class="mb-3 text-primary">
            <i class="bi bi-telephone-outbound" style="font-size: 2rem;"></i>
          </div>
          <h5 class="fw-bold">Телефон</h5>
          <%= phone_to @organization.phones.last.phone, class: "text-white text-decoration-none fs-5" %>
        </div>
      </div>

      <%# Адрес %>
      <div class="col-12 col-md-4 border-start border-end border-secondary border-opacity-25">
        <div class="p-3">
          <div class="mb-3 text-primary">
            <i class="bi bi-geo-alt" style="font-size: 2rem;"></i>
          </div>
          <h5 class="fw-bold">Адрес</h5>
          <p class="fs-5 mb-0">г. Ессентуки</p>
        </div>
      </div>

      <%# График %>
      <div class="col-12 col-md-4">
        <div class="p-3">
          <div class="mb-3 text-primary">
            <i class="bi bi-clock" style="font-size: 2rem;"></i>
          </div>
          <h5 class="fw-bold">Режим работы</h5>
          <p class="fs-5 mb-0">Ежедневно: 9:00 — 21:00</p>
        </div>
      </div>
    </div>

    <%# Кнопка быстрой связи (WhatsApp/Telegram) если нужно %>
    <div class="mt-5">
      <hr class="w-25 mx-auto mb-4 opacity-25">
      <p class="small text-secondary text-uppercase letter-spacing-1">Срочный вопрос? Пишите в мессенджеры</p>
      <div class="d-flex justify-content-center gap-3 mt-3">
         <button class="btn btn-outline-light rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#exampleModal5">
           Открыть чат
         </button>
      </div>
    </div>
  </div>
</section>

      <footer class="bg-dark text-white text-center py-4 footer">
      © <%= Time.now.year %> Профессиональный сервис бытовой техники. Все права защищены.
      <p>
        Сайт разрботан в
        <i>
          <b>
            <%= link_to 'https://idea-creation.ru', style:"text-decoration: none;font-family: 'BankGothic', sans-serif; font-size: 25px;" do %>
              <%= image_tag('/images/logo.png', style:'width: 5rem;')  %>
              IDEA
            <% end %>
          </b>
        </i>
      </p>
    </footer>
    <%= render 'include/modal' %>
  </body>
</html>

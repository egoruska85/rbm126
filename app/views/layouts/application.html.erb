            <%= link_to 'https://idea-creation.ru', style:"text-decoration: none;font-family: 'BankGothic', sans-serif; font-size: 25px;" do %>
              <%= image_tag('/images/logo.png', style:'width: 5rem;')  %>
              IDEA
            <% end %>
          </b>
        </i>
      </p>
    </footer>
  </body>
</html>

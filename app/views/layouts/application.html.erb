<!DOCTYPE html>
<html>
  <head>
    <%= display_meta_tags title: @page_title, description: @page_description, keywords: @page_keywords %>
    <%= favicon_link_tag '/images/logo_0.png' %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script src="https://api-maps.yandex.ru" type="text/javascript"></script>

    <link href="https://cdn.jsdelivr.net/npm/lightbox2@2/dist/css/lightbox.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/lightbox2@2/dist/js/lightbox.min.js"></script>

    <style media="screen">
      html, body {
        height: 100%;
        margin: 0;
      }

      .wrapper {
        min-height: 84.6vh;       /* вся высота экрана */
        display: flex;
        flex-direction: column;
      }

      .content {
        flex: 1;                /* занимает всё свободное место */
      }

      .footer {
        background: #333;
        color: white;
        padding: 20px;
      }
    </style>
  </head>

  <body>
    <div class="wrapper">
      <main class="content">
    <%= yield %>
        </main>
      </div>
      <footer class="bg-dark text-white text-center py-4 footer">
      © <%= Time.now.year %> Профессиональный сервис бытовой техники. Все права защищены.
    </footer>
  </body>
</html>

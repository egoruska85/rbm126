<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8">
    <title></title>
    <style>
      body { padding-top: 110px; }

      .parallax-service {
        background-image: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)),
                          url(<%= rails_blob_url(@service.image) if @service.image.attached? %>);
        min-height: 90vh;
        background-attachment: fixed;
        background-position: center;
        background-repeat: no-repeat;
        background-size: cover;
        display: flex;
        align-items: center;
        padding: 50px 0;
      }

      .glass-card {
        background-color: rgba(0, 0, 0, 0.85);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
      }

      .price-item {
        transition: 0.2s;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        padding: 10px 0;
      }

      .price-item:hover {
        background: rgba(255, 255, 255, 0.05);
        padding-left: 10px;
      }
    </style>

  </head>
  <body>
    <%= render 'include/navbar' %>
    <section class="parallax-service">
      <div class="container">
        <div class="row justify-content-center g-4">

          <%# Левая колонка: Заголовок и призыв к действию %>
          <div class="col-12 col-lg-5 text-center text-lg-start d-flex flex-column justify-content-center">
            <h1 class="display-3 fw-bold text-white mb-4"><%= @service.title %></h1>
            <p class="lead text-white-50 mb-5">Профессиональный ремонт с гарантией качества. Используем только оригинальные запчасти.</p>
            <div class="d-grid d-md-flex gap-3">
              <button class="btn btn-primary btn-lg px-5 shadow" data-bs-toggle="modal" data-bs-target="#exampleModal3">
                Заказать ремонт
              </button>
            </div>
          </div>

          <%# Правая колонка: Прайс-лист %>
          <div class="col-12 col-lg-6">
            <div class="card glass-card p-4 p-md-5 shadow-lg rounded-4 text-white">
              <h3 class="mb-4 fw-bold border-bottom pb-3">Цены на услуги</h3>

              <div class="service-list">
                <% if @service.subservices.any? %>
                  <% @service.subservices.each do |subservice| %>
                    <div class="d-flex justify-content-between align-items-center price-item">
                      <span class="fs-5"><%= subservice.title %></span>
                      <span class="fw-bold text-primary fs-5"><%= subservice.price %> ₽</span>
                    </div>
                  <% end %>
                <% else %>
                  <p class="text-white-50">Список работ уточняйте у мастера</p>
                <% end %>
              </div>

              <div class="mt-4 pt-3 small text-white-50">
                * Итоговая стоимость зависит от сложности и запчастей.
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>
    <%= render 'modal' %>
  </body>
</html>

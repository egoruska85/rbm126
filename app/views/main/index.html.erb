<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Сервисный центр</title>

  <!-- Bootstrap CSS -->


  <style>
    body {
      padding-top: 80px;
    }

    /* Исправленный параллакс */
    .parallax {
      background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)),
                        url(<%= rails_blob_url(@parallax) %>);
      height: 100vh;
      background-attachment: fixed;
      background-position: center;
      background-repeat: no-repeat;
      background-size: cover;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Отключаем fixed на мобилках для стабильности */
    @media (max-width: 768px) {
      .parallax { background-attachment: scroll; height: 50vh; }
    }

    .hero {
      /* Добавляем легкое наложение, чтобы текст всегда читался */
      background: linear-gradient(rgba(255,255,255,0.8), rgba(255,255,255,0.8)),
                  url(<%= rails_blob_url(@heroimage) %>);
      background-size: cover;
      background-position: center;
      padding: 100px 20px;
      text-align: center;
    }

    .hero h1 {
      font-weight: 700;
    }

    /* Стили карточек */
    .card {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.15);
    }

    /* Стили карты вынесены из hover */
    .map-wrapper {
      width: 100%;
      height: 400px;
      overflow: hidden;
      border-radius: 15px;
    }

    .map-wrapper iframe {
      width: 100%;
      height: 100%;
      border: 0;
      display: block;
    }
  </style>

</head>
<body>

<!-- NAVBAR -->
<%= render 'include/navbar' %>


<!-- HERO -->
<section class="hero text-black">
    <div class="container text-center">
      <h1 class="display-3 fw-bold mb-3">Ремонт бытовой техники</h1>
      <p class="lead fs-4 mb-5">Выезд мастера в день обращения. <b>Гарантия до 12 месяцев.</b></p>

      <div class="d-flex flex-column flex-sm-row justify-content-center gap-4">
        <button type="button" class="btn btn-primary btn-lg btn-hero shadow" data-bs-toggle="modal" data-bs-target="#exampleModal">
          Оставить заявку
        </button>
        <button type="button" class="btn btn-outline-dark btn-lg btn-hero" data-bs-toggle="modal" data-bs-target="#exampleModal2">
          Консультация
        </button>
      </div>
    </div>
</section>



<!-- Button trigger modal -->
<%= render "modals" %>



<!-- SERVICES -->
<section id="services" class="parallax">
  <div class="container">
    <div class="text-center">
      <h2 class="section-title text-white">НАШИ УСЛУГИ</h2>
    </div>

    <div class="row g-4 mt-2">
      <% @services.each do |service| %>
        <div class="col-6 col-md-4 col-lg-3">
          <%= link_to service_path(service), class: "text-decoration-none" do %>
            <div class="card service-card h-100 text-white p-3 text-center">
              <div class="card-body d-flex align-items-center justify-content-center">
                <h5 class="fw-bold m-0"><%= service.title %></h5>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="text-center mt-5">
       <%= link_to 'СМОТРЕТЬ ВСЕ УСЛУГИ', services_path, class: "btn btn-link text-white opacity-75 text-decoration-none" %>
    </div>
  </div>
</section>


<!-- ADVANTAGES -->

<section id="abouts" class="section py-5 bg-light">
  <div class="container">
    <%# Блок текста "О нас" %>
    <div class="row justify-content-center mb-5">
      <div class="col-lg-10 text-center shadow-sm p-5 bg-white rounded-4">
        <h2 class="section-title mb-4">О нас</h2>
        <div class="lead text-secondary" style="font-size: 1.1rem; line-height: 1.8;">
          <%= simple_format @organization.about %>
        </div>
      </div>
    </div>

    <%# Блок "Почему выбирают нас" %>
    <div class="text-center mt-5">
      <h3 class="fw-bold mb-5">Почему выбирают нас</h3>
      <div class="row g-4">
        <% @entries.each do |enter| %>
          <div class="col-md-6 col-lg-3">
            <div class="card p-4 shadow-sm h-100 border-0 rounded-4 transition-hover">
              <div class="card-body d-flex flex-column align-items-center">
                <%# Плейсхолдер для иконки - можно заменить на конкретные bi-icons %>
                <div class="feature-icon-small bg-primary bg-gradient text-white mb-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                  <%= raw enter.path1 %> 
                </div>
                <h5 class="fw-bold text-dark m-0"><%= enter.title %></h5>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>


<!-- CONTACTS -->
<section id="contacts-form" class="py-5 bg-light">
  <div class="container bg-white shadow-lg rounded-5 overflow-hidden p-0">
    <div class="row g-0">
      <!-- Карта (теперь на всю высоту) -->
      <div class="col-12 col-lg-5">
        <div style="height: 100%; min-height: 450px;">
          <script type="text/javascript" charset="utf-8" async src="https://api-maps.yandex.ru/services/constructor/1.0/js/?um=constructor%3A6f0290fe81bea1501ab1148db63aed00c2c17880bdf5566d588151e09c447503&amp;width=320&amp;height=554&amp;lang=ru_RU&amp;scroll=true"></script>

        </div>
      </div>

      <!-- Форма -->
      <div class="col-12 col-lg-7 p-4 p-md-5">
        <h2 class="fw-bold mb-4">Связаться с нами</h2>
        <%= form_for @contact, html: { class: "row g-3" } do |f| %>
          <div class="col-md-6">
            <%= f.text_field :name, class: 'form-control form-control-lg bg-light border-0', placeholder: "Ваше имя" %>
          </div>
          <div class="col-md-6">
            <%= f.text_field :email, class: 'form-control form-control-lg bg-light border-0', placeholder: "Email" %>
          </div>
          <div class="col-12">
            <%= f.text_field :phone, class: 'form-control form-control-lg bg-light border-0', value: '+7', placeholder: "Ваш телефон" %>
          </div>
          <div class="col-12">
            <%= f.text_area :message, class: 'form-control bg-light border-0', rows: 4, placeholder: "Какая техника сломалась?" %>
          </div>
          <div class="col-12">
            <div class="small text-muted mb-2">Прикрепите фото поломки</div>
            <%= f.file_field :file, class: 'form-control border-0 bg-light', multiple: true %>
          </div>
          <div class="col-12 mt-4">
            <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill shadow py-3">ОТПРАВИТЬ СООБЩЕНИЕ</button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>


<hr>



<!-- Bootstrap JS -->

</body>
</html>

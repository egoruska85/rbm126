<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8">
    <title></title>
    <style>
      body {
        padding-top: 80px;

      }

      .hero {
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        padding: 100px 20px;
        text-align: left;
      }

      .hero h1 {
        font-weight: 700;
      }

      .section {
        padding: 80px 0;
      }

      .card:hover {
        transform: translateY(-5px);
        transition: 0.3s;


      }
    </style>
  </head>
  <body>
    <%= render "include/navbar" %>
    <div class="container my-5">
      <div class="row g-4">

        <%# --- ЛЕВАЯ КОЛОНКА: ДЕТАЛИ ЗАЯВКИ --- %>
        <div class="col-12 col-lg-7">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
              <li class="breadcrumb-item"><%= link_to 'Кабинет', frontoffices_path %></li>
              <li class="breadcrumb-item active">Заявка #<%= @order.id %></li>
            </ol>
          </nav>

          <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">
              <div class="d-flex justify-content-between align-items-start mb-3">
                <h1 class="h3 fw-bold">Заявка #000<%= @order.id %></h1>
                <%# Динамический статус %>
                <% if @order.completed? %>
                  <span class="badge bg-success px-3 py-2">✅ Выполнено</span>
                <% elsif @order.accepted? %>
                  <span class="badge bg-info text-dark px-3 py-2">⚙️ В процессе</span>
                <% else %>
                  <span class="badge bg-warning text-dark px-3 py-2">⏳ Ожидает мастера</span>
                <% end %>
              </div>

              <div class="bg-light p-3 rounded mb-4">
                <h6 class="text-muted small text-uppercase fw-bold">Ваше описание:</h6>
                <p class="mb-0 text-dark"><%= @order.desc %></p>
              </div>

              <h6 class="text-muted small text-uppercase fw-bold mb-3">Прикрепленные фото:</h6>
              <div class="d-flex flex-wrap gap-2">
                <% if @order.images.attached? %>
                  <% @order.images.each do |image| %>
                    <%= image_tag image,
                        class: "rounded shadow-sm img-thumbnail",
                        style: "width: 140px; height: 140px; object-fit: cover; cursor: zoom-in;",
                        data: { bs_toggle: "modal", bs_target: "#imgModal", url: url_for(image) } %>
                  <% end %>
                <% else %>
                  <p class="text-muted italic">Фотографии не были прикреплены</p>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <%# --- ПРАВАЯ КОЛОНКА: ЧАТ С МАСТЕРОМ --- %>
        <div class="col-12 col-lg-5">
          <div class="card shadow-sm border-0 d-flex flex-column" style="height: 600px;">
            <div class="card-header bg-primary text-white py-3">
              <h5 class="mb-0 d-flex align-items-center">
                <i class="bi bi-chat-dots-fill me-2"></i> Чат с поддержкой
              </h5>
            </div>

            <div class="card-body overflow-auto bg-light p-3" id="messages">
              <%= turbo_stream_from "messages" %>
              <% @messages.each do |message| %>
                <div class="d-flex mb-3 <%= message.user_id == current_user.id ? 'justify-content-end' : 'justify-content-start' %>">
                  <div class="p-3 rounded-3 shadow-sm <%= message.user_id == current_user.id ? 'bg-primary text-white' : 'bg-white text-dark border' %>" style="max-width: 85%;">
                    <small class="d-block mb-1 fw-bold opacity-75">
                      <%= message.user_id == current_user.id ? "Вы" : "Мастер" %>
                    </small>
                    <%= message.body %>
                  </div>
                </div>
              <% end %>
            </div>

            <div class="card-footer bg-white border-top-0 p-3">
              <%= form_with(model: [@order, Message.new], class: "d-flex gap-2") do |f| %>
                <%= f.text_area :body, class: "form-control border-2", placeholder: "Задать вопрос...", rows: 1 %>
                <button type="submit" class="btn btn-primary px-3">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-send-fill" viewBox="0 0 16 16">
  <path d="M15.964.686a.5.5 0 0 0-.65-.65L.767 5.855H.766l-.452.18a.5.5 0 0 0-.082.887l.41.26.001.002 4.995 3.178 3.178 4.995.002.002.26.41a.5.5 0 0 0 .886-.083zm-1.833 1.89L6.637 10.07l-.215-.338a.5.5 0 0 0-.154-.154l-.338-.215 7.494-7.494 1.178-.471z"/>
</svg>
                </button>
              <% end %>
            </div>
          </div>
        </div>

      </div>
    </div>

    <%# Модальное окно для просмотра фото %>
    <div class="modal fade" id="imgModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bg-transparent border-0">
          <img id="modalImg" src="" class="img-fluid rounded shadow-lg">
        </div>
      </div>
    </div>

    <script>
      // Используем turbo:load для совместимости с Hotwire/Turbo
      document.addEventListener("turbo:load", function() {
        const modalElement = document.getElementById('imgModal');

        // Проверяем, существует ли модалка на текущей странице
        if (modalElement) {
          modalElement.addEventListener('show.bs.modal', function(event) {
            const button = event.relatedTarget; // Кнопка/картинка, на которую нажали
            const imageUrl = button.getAttribute('data-url'); // Берем URL из data-url
            const modalImage = document.getElementById('modalImg');

            if (modalImage) {
              modalImage.src = imageUrl;
            }
          });
        }

        // Автоскролл чата вниз
        const msgContainer = document.getElementById('messages');
        if (msgContainer) {
          msgContainer.scrollTop = msgContainer.scrollHeight;
        }
      });
    </script>


  </body>
</html>

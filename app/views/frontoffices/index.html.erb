<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8">
    <title></title>
    <style>
      body {
        padding-top: 80px;

      }

      .hero {
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        padding: 100px 20px;
        text-align: left;
      }

      .past-hero {
        background: linear-gradient(135deg, #64748b, #334155);
        color: white;
        padding: 100px 20px;
        text-align: left;
      }

      .hero h1 {
        font-weight: 700;
      }

      .past-hero h1 {
        font-weight: 700;
      }


      .section {
        padding: 80px 0;
      }

      .card:hover {
        transform: translateY(-5px);
        transition: 0.3s;


      }
    </style>
  </head>
  <body>
    <%= render "include/navbar" %>
    <div class="container my-5">
      <%# ПРИВЕТСТВИЕ %>
      <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
          <h1 class="display-6 fw-bold mb-0">Личный кабинет</h1>
          <p class="text-muted">Добро пожаловать, <%= current_user.username %>!</p>
        </div>
        <div class="text-end">
          <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 rounded-pill">
            Активных заявок: <%= @current_orders.count %>
          </span>
        </div>
      </div>

      <%# СЕКЦИЯ: ТЕКУЩИЕ ОБРАЩЕНИЯ %>
      <h3 class="mb-3 mt-5"><i class="bi bi-tools me-2"></i>Текущие обращения</h3>
      <div class="row g-4 mb-5">
        <% if @current_orders.any? %>
          <% @current_orders.each do |order| %>
            <div class="col-12 col-md-6">
              <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                  <div class="d-flex gap-3">
                    <%# Миниатюра %>
                    <div style="flex-shrink: 0;">
                      <% if order.images.attached? %>
                        <%= image_tag order.images.first, class: "rounded", style: "width: 80px; height: 80px; object-fit: cover;" %>
                      <% else %>
                        <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                          <i class="bi bi-camera text-muted"></i>
                        </div>
                      <% end %>
                    </div>

                    <%# Контент %>
                    <div class="flex-grow-1">
                      <h5 class="card-title mb-1"><%= order.desc %></h5>
                      <p class="text-muted small mb-2"><%= order.service.title %></p>

                      <div class="mb-3">
                        <% if order.completed? %>
                          <span class="badge bg-success">Выполнено</span>
                        <% elsif order.accepted? %>
                          <span class="badge bg-info text-dark">В процессе</span>
                        <% else %>
                          <span class="badge bg-warning text-dark">Ожидает подтверждения</span>
                        <% end %>
                      </div>

                      <%= link_to frontoffice_path(order), class: 'btn btn-primary btn-sm px-4 rounded-pill' do %>
                        Открыть детали <i class="bi bi-arrow-right ms-1"></i>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="col-12">
            <div class="alert alert-light border text-center py-4">
              У вас пока нет активных заявок.
            </div>
          </div>
        <% end %>
      </div>

      <%# СЕКЦИЯ: ПРОШЛЫЕ ОБРАЩЕНИЯ %>
      <h3 class="mb-3"><i class="bi bi-archive me-2"></i>История обращений</h3>
      <div class="card shadow-sm border-0 overflow-hidden">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th class="ps-4">Услуга</th>
                <th>Описание</th>
                <th>Статус</th>
                <th class="text-end pe-4">Действие</th>
              </tr>
            </thead>
            <tbody>
              <% @past_orders.each do |order| %>
                <tr>
                  <td class="ps-4">
                    <span class="fw-bold"><%= order.service.title %></span>
                  </td>
                  <td class="text-muted"><%= truncate(order.desc, length: 50) %></td>
                  <td><span class="badge bg-secondary">Архив</span></td>
                  <td class="text-end pe-4">
                    <%= link_to 'Просмотр', frontoffice_path(order), class: 'btn btn-link btn-sm' %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </body>
</html>

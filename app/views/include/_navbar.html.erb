            <% if current_user.admin? %>
              <%# Кнопки Админа %>
              <%= link_to backoffices_path, class: "btn btn-outline-primary btn-sm", title: "Панель управления" do %>
                <i class="bi bi-building"></i> Управление
              <% end %>
            <% else %>
              <%# Кнопки Юзера %>
              <%= phone_to @organization.phones.last&.phone, class: "btn btn-success btn-sm d-flex align-items-center gap-2" do %>

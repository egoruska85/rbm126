        <li class="nav-item"><%= link_to 'О нас', root_path(anchor: 'abouts'), class: "nav-link" %></li>
        <li class="nav-item"><%= link_to 'Контакты', root_path(anchor: 'contacts'), class: "nav-link" %></li>

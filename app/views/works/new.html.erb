<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8">
    <title></title>
    <style>
      body {
        padding-top: 80px;

      }

      .hero {
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        padding: 100px 20px;
        text-align: left;
      }

      .hero h1 {
        font-weight: 700;
      }

      .section {
        padding: 80px 0;
      }

      .card:hover {
        transform: translateY(-5px);
        transition: 0.3s;


      }


    </style>
  </head>
  <body>
    <%= render 'include/navbar' %>
    <section class="hero py-5">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-md-6">
            <h1 class="display-5 mb-4 text-center">Добавить выполненную работу</h1>

            <%= form_with model: @work, class: "card p-4 shadow-sm" do |f| %>
              <div class="mb-3">
                <%= f.label :title, "Наименование работы", class: "form-label" %>
                <%= f.text_field :title, class: 'form-control', placeholder: 'Например: Установка кондиционера' %>
              </div>

              <div class="mb-3">
                <%= f.label :body, "Описание работ", class: "form-label" %>
                <%= f.text_area :body, class: 'form-control', rows: 4, placeholder: 'Что именно было сделано...' %>
              </div>

              <div class="mb-4">
                <%= f.label :images, "Фотографии", class: "form-label" %>
                <%= f.file_field :images, multiple: true, class: 'form-control' %>
                <div class="form-text">Можно выбрать несколько файлов</div>
              </div>

              <%= f.button type: "submit", class: "btn btn-primary w-100 d-flex align-items-center justify-content-center gap-2" do %>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-plus-circle-fill" viewBox="0 0 16 16">
                  <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0M8.5 4.5a.5.5 0 0 0-1 0v3h-3a.5.5 0 0 0 0 1h3v3a.5.5 0 0 0 1 0v-3h3a.5.5 0 0 0 0-1h-3z"/>
                </svg>
                Сохранить работу
              <% end %>
            <% end %>

          </div>
        </div>
      </div>
    </section>

  </body>
</html>

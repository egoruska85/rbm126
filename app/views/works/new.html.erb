<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8">
    <title></title>
    <style>
      body {
        padding-top: 80px;

      }

      .hero {
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        padding: 100px 20px;
        text-align: left;
      }

      .hero h1 {
        font-weight: 700;
      }

      .section {
        padding: 80px 0;
      }

      .card:hover {
        transform: translateY(-5px);
        transition: 0.3s;


      }


    </style>
  </head>
  <body>
    <%= render 'include/navbar' %>
    <section class="hero py-5">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-md-7 col-lg-6">

            <%# Навигация назад %>
            <div class="mb-4">
              <%= link_to works_path, class: "text-white text-decoration-none small" do %>
                <i class="bi bi-arrow-left"></i> Назад к списку работ
              <% end %>
            </div>

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
              <div class="card-header bg-dark text-white p-4 border-0">
                <h2 class="h4 mb-0 text-center text-white">Добавить выполненную работу</h2>
              </div>

              <div class="card-body p-4 p-md-5 bg-white text-dark">
                <%= form_with model: @work, class: "needs-validation" do |f| %>

                  <div class="mb-3">
                    <%= f.label :title, "Наименование работы", class: "form-label fw-bold" %>
                    <%= f.text_field :title, class: 'form-control form-control-lg', placeholder: 'Например: Ремонт стиральной машины Bosch', required: true %>
                  </div>

                  <div class="mb-3">
                    <%= f.label :body, "Описание работ", class: "form-label fw-bold" %>
                    <%= f.text_area :body, class: 'form-control', rows: 5, placeholder: 'Опишите поломку и процесс ремонта...', required: true %>
                  </div>

                  <div class="mb-4">
                    <%= f.label :images, "Фотографии (перетаскивайте для сортировки)", class: "form-label fw-bold" %>
                    <%= f.file_field :images,
                          multiple: true,
                          class: 'form-control',
                          id: 'image-input',
                          accept: 'image/*' %>

                    <div id="image-preview" class="d-flex flex-wrap gap-3 mt-3">
                      <%# Сюда JS будет добавлять картинки %>
                    </div>
                  </div>


                  <%= f.button type: "submit", class: "btn btn-primary btn-lg w-100 d-flex align-items-center justify-content-center gap-2 rounded-pill shadow-sm" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-cloud-arrow-up-fill" viewBox="0 0 16 16">
                      <path d="M8 2a5.53 5.53 0 0 0-3.594 1.342c-.766.66-1.321 1.52-1.464 2.383C1.266 6.095 0 7.555 0 9.318 0 11.366 1.708 13 3.781 13h8.906C14.502 13 16 11.57 16 9.773c0-1.636-1.242-2.969-2.834-3.194C12.923 3.999 10.69 2 8 2m2.354 5.146a.5.5 0 0 1-.708.708L8.5 6.707V10.5a.5.5 0 0 1-1 0V6.707L6.354 7.854a.5.5 0 1 1-.708-.708l1.5-1.5a.5.5 0 0 1 .708 0z"/>
                    </svg>
                    Опубликовать работу
                  <% end %>
                <% end %>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>
    <script>
  document.addEventListener('turbo:load', function() {
    const input = document.getElementById('image-input');
    const preview = document.getElementById('image-preview');
    let filesArray = [];

    if (!input || !preview) return;

    input.addEventListener('change', function() {
      const newFiles = Array.from(this.files);
      filesArray = filesArray.concat(newFiles);
      render();
    });

    function render() {
      preview.innerHTML = '';
      filesArray.forEach((file, index) => {
        const reader = new FileReader();
        reader.onload = (e) => {
          const div = document.createElement('div');
          div.className = 'position-relative border rounded p-1 bg-white shadow-sm';
          div.style.width = '100px';
          div.style.cursor = 'move';
          div.draggable = true; // Включаем перетаскивание
          div.dataset.index = index;

          div.innerHTML = `
            <img src="${e.target.result}" class="w-100 rounded" style="height:80px; object-fit:cover; pointer-events:none;">
            <div class="btn btn-danger btn-sm position-absolute top-0 end-0 d-flex align-items-center justify-content-center"
                 style="width:20px; height:20px; margin:-5px -5px 0 0; cursor:pointer;"
                 onclick="window.removeFile(${index})">×</div>
          `;

          // События для Drag and Drop
          div.addEventListener('dragstart', handleDragStart);
          div.addEventListener('dragover', handleDragOver);
          div.addEventListener('drop', handleDrop);

          preview.appendChild(div);
        };
        reader.readAsDataURL(file);
      });
      syncInput();
    }

    // Удаление (выносим в window, чтобы onclick сработал)
    window.removeFile = (index) => {
      filesArray.splice(index, 1);
      render();
    };

    // --- Логика Drag and Drop ---
    let draggedItemIndex = null;

    function handleDragStart(e) {
      draggedItemIndex = this.dataset.index;
      e.dataTransfer.effectAllowed = 'move';
    }

    function handleDragOver(e) {
      e.preventDefault();
      return false;
    }

    function handleDrop(e) {
      e.preventDefault();
      const targetIndex = this.dataset.index;

      // Меняем элементы местами в массиве
      const itemToMove = filesArray.splice(draggedItemIndex, 1)[0];
      filesArray.splice(targetIndex, 0, itemToMove);

      render();
    }

    // Синхронизация массива с input.files
    function syncInput() {
      const dt = new DataTransfer();
      filesArray.forEach(file => dt.items.add(file));
      input.files = dt.files;
    }
  });
</script>




  </body>
</html>

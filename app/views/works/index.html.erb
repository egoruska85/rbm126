<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8">
    <title></title>
    <style>
      body { padding-top: 80px; }

      /* Улучшенный эффект для карточек */
      .card {
        transition: all 0.3s ease;
      }

      .card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
      }

      /* Фиксация пропорций изображений */
      .card-img-top-wrapper {
        position: relative;
        width: 100%;
        height: 250px;
        background-color: #f8f9fa;
      }

      /* Стили для параллакса (если используете на других страницах) */
      .parallax {
        min-height: 500px;
        background-attachment: fixed;
        background-position: center;
        background-repeat: no-repeat;
        background-size: cover;
      }
    </style>
  </head>
  <body>
    <%= render 'include/navbar' %>


    <section class="portfolio py-5" style="background-color: #f4f7f6;">
      <div class="container">
        <h1 class="display-5 mb-2 text-center fw-bold">Наши работы</h1>
        <p class="text-center text-muted mb-4">Примеры выполненных заказов и результаты нашего ремонта</p>
        <hr class="mx-auto mb-5" style="width: 100px; height: 3px; background: #0d6efd; opacity: 1;">

        <div class="row g-4">
          <% if @works.present? %>
            <% @works.each do |work| %>
              <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm border-0 rounded-3">

                  <div class="card-img-top-wrapper">
                    <% if work.images.attached? %>
                      <%= image_tag work.images.first, class: "card-img-top h-100 w-100", style: "object-fit: cover;" %>
                    <% else %>
                      <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted opacity-50">
                        <i class="bi bi-image" style="font-size: 2rem;"></i>
                        <small>Нет фотографий</small>
                      </div>
                    <% end %>
                  </div>

                  <div class="card-body d-flex flex-column p-4">
                    <h5 class="card-title fw-bold mb-3"><%= work.title %></h5>
                    <p class="card-text text-secondary mb-4">
                      <%= truncate(work.body, length: 110) %>
                    </p>
                    <div class="mt-auto">
                      <%= link_to work_path(work), class: 'btn btn-primary w-100 rounded-pill py-2 shadow-sm' do %>
                        Смотреть детали
                      <% end %>
                    </div>
                  </div>

                  <% if user_signed_in? && current_user.admin? %>
                    <div class="card-footer bg-light border-0 d-flex justify-content-end p-3">
                      <%= link_to edit_work_path(work), class: 'btn btn-sm btn-outline-secondary' do %>
                        <i class="bi bi-pencil"></i> Изменить
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="col-12 py-5 text-center">
              <div class="bg-white p-5 rounded-4 shadow-sm d-inline-block">
                 <p class="lead text-muted mb-0">Работы пока не опубликованы</p>
              </div>
            </div>
          <% end %>
        </div>

        <% if user_signed_in? && current_user.admin? %>
          <div class="text-center mt-5">
            <%= link_to new_work_path, class: 'btn btn-dark btn-lg px-5 py-3 rounded-pill shadow' do %>
              <i class="bi bi-plus-circle me-2"></i> Опубликовать новую работу
            <% end %>
          </div>
        <% end %>
      </div>
    </section>

  </body>
</html>

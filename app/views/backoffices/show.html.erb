<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8">
    <title></title>
    <style>
      body {
        padding-top: 80px;

      }

      .hero {
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        padding: 100px 20px;
        text-align: left;
      }

      .hero h1 {
        font-weight: 700;
      }

      .section {
        padding: 80px 0;
      }

      .card:hover {
        transform: translateY(-5px);
        transition: 0.3s;


      }


    </style>

  </head>
  <body>
    <%= render "include/navbar" %>
    <div class="container my-5">
      <div class="row g-4">

        <%# --- ЛЕВАЯ КОЛОНКА: ИНФОРМАЦИЯ О ЗАЯВКЕ --- %>
        <div class="col-12 col-lg-7">
          <div class="card shadow-sm border-0 pt-3">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h1 class="h3 mb-0 text-primary">Заявка #000<%= @order.id %></h1>
                <div class="d-flex gap-2">
                  <%# Кнопка Принять %>
                  <%= button_to toggle_active_backoffice_path(@order), method: :patch,
                      class: "btn btn-sm #{ @order.accepted ? 'btn-success' : 'btn-outline-warning' }" do %>
                    <%= @order.accepted ? '✅ Принято' : '⛔ Принять' %>
                  <% end %>

                  <%# Кнопка Выполнено %>
                  <% if @order.accepted? %>
                    <%= button_to toggle_completed_backoffice_path(@order), method: :patch,
                        class: "btn btn-sm #{ @order.completed ? 'btn-success' : 'btn-outline-primary' }" do %>
                      <%= @order.completed ? '✅ Выполнено' : '⚙️ В процессе' %>
                    <% end %>
                  <% end %>
                </div>
              </div>

              <hr>
              <p class="lead mb-4"><%= @order.desc %></p>

              <div class="mb-4">
                <h6 class="text-muted small">Клиент:</h6>
                <h5><%= @order.name %></h5>
                <%= phone_to @order.phone, class: "btn btn-outline-success mt-2" do %>
                  <i class="bi bi-telephone-fill me-2"></i><%= @order.phone %>
                <% end %>
              </div>

              <h6 class="text-muted small">Фотографии:</h6>
              <div class="d-flex flex-wrap gap-2 mt-2">
                <% if @order.images.attached? %>
                  <% @order.images.each do |image| %>
                  <%= image_tag image,
                                      class: "rounded shadow-sm",
                                      style: "width: 80px; height: 80px; object-fit: cover; cursor: pointer;",
                                      data: {
                                        bs_toggle: "modal",
                                        bs_target: "#listImageModal",
                                        url: url_for(image)
                                      } %>
                  <% end %>
                <% else %>
                  <%= image_tag '/images/no_photo.png', style: "width: 100px;", class: "opacity-50" %>
                <% end %>


              </div>
            </div>
          </div>
        </div>

        <%# --- ПРАВАЯ КОЛОНКА: МЕССЕНДЖЕР --- %>
        <div class="col-12 col-lg-5">
          <div class="card shadow-sm border-0 d-flex flex-column" style="height: 600px;">
            <div class="card-header bg-dark text-white py-3">
              <h5 class="mb-0">Чат по заявке</h5>
            </div>

            <div class="card-body overflow-auto bg-light" id="messages-list">
              <%= turbo_stream_from "messages" %>
              <% @messages.each do |message| %>
                <div class="mb-3 d-flex <%= message.user_id == current_user.id ? 'justify-content-end' : 'justify-content-start' %>">
                  <div class="p-3 rounded shadow-sm <%= message.user_id == current_user.id ? 'bg-primary text-white' : 'bg-white text-dark' %>" style="max-width: 85%;">
                    <small class="d-block mb-1 opacity-75 fw-bold">
                      <%= message.user_id == current_user.id ? "Вы" : message.user.username %>
                    </small>
                    <%= message.body %>
                  </div>
                </div>
              <% end %>
            </div>

            <div class="card-footer bg-white border-top-0 p-3">
              <%= form_with(model: [@order, Message.new], class: "d-flex gap-2") do |f| %>
                <%= f.text_area :body, class: "form-control", placeholder: "Напишите...", rows: 1 %>
                <%= f.button type: "submit", class: "btn btn-primary" do %>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-send-fill" viewBox="0 0 16 16">
<path d="M15.964.686a.5.5 0 0 0-.65-.65L.767 5.855H.766l-.452.18a.5.5 0 0 0-.082.887l.41.26.001.002 4.995 3.178 3.178 4.995.002.002.26.41a.5.5 0 0 0 .886-.083zm-1.833 1.89L6.637 10.07l-.215-.338a.5.5 0 0 0-.154-.154l-.338-.215 7.494-7.494 1.178-.471z"/>
</svg>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>

      </div>
    </div>

    <%# --- МОДАЛЬНОЕ ОКНО ДЛЯ ФОТО --- %>
    <%# --- МОДАЛЬНОЕ ОКНО (Общее для всех картинок на странице) --- %>
    <div class="modal fade" id="listImageModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bg-transparent border-0">
          <div class="modal-body p-0 text-center">
            <img id="modalImgTarget" src="" class="img-fluid rounded shadow-lg">
          </div>
        </div>
      </div>
    </div>

    <script>
      // Скрипт с поддержкой Turbo
      document.addEventListener("turbo:load", function() {
        const modalElement = document.getElementById('listImageModal');
        if (modalElement) {
          modalElement.addEventListener('show.bs.modal', function(event) {
            const triggerImage = event.relatedTarget;
            const imageUrl = triggerImage.getAttribute('data-url');
            document.getElementById('modalImgTarget').src = imageUrl;
          });
        }
      });
    </script>


  </body>
</html>

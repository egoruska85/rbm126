<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8">
    <title></title>
    <style>
      body {
        padding-top: 80px;

      }

      .hero {
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        padding: 100px 20px;
        text-align: left;
      }

      .hero-completed {
        background: linear-gradient(135deg, #64748b, #334155);
        color: white;
        padding: 100px 20px;
        text-align: left;
      }

      .hero h1 {
        font-weight: 700;
      }

      .hero-completed h1 {
        font-weight: 700;
      }

      .section {
        padding: 80px 0;
      }

      .card:hover {
        transform: translateY(-5px);
        transition: 0.3s;


      }
    </style>
  </head>
  <body>
    <%= render "include/navbar" %>
    <div class="container my-5">

      <%# --- СЕКЦИЯ: ТЕКУЩИЕ ЗАЯВКИ --- %>
      <section class="card shadow-sm mb-5 border-0">
        <div class="card-header bg-primary text-white p-3">
          <h2 class="h4 mb-0"><i class="bi bi-clock-history me-2"></i>Текущие заявки</h2>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Фото</th>
                  <th>Описание и Услуга</th>
                  <th>Клиент</th>
                  <th>Статус</th>
                  <th class="text-end">Действие</th>
                </tr>
              </thead>
              <tbody>
                <% @orders.each do |order| %>
                  <tr>
                    <td style="width: 120px;">
                      <% if order.images.attached? %>
                        <%= image_tag order.images.first, class: "rounded img-thumbnail", style: "width: 100px; height: 70px; object-fit: cover;" %>
                      <% else %>
                        <div class="bg-light rounded text-center small text-muted p-2" style="width: 100px;">Нет фото</div>
                      <% end %>
                    </td>
                    <td>
                      <div class="fw-bold"><%= order.desc %></div>
                      <small class="text-muted"><%= order.service.title %></small>
                    </td>
                    <td><%= order.name %></td>
                    <td>
                      <%# Логика бейджей статуса %>
                      <% if order.completed? %>
                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Выполнено</span>
                      <% elsif order.accepted? %>
                        <span class="badge bg-info text-dark"><i class="bi bi-gear-fill"></i> В процессе</span>
                      <% else %>
                        <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-triangle"></i> Новая</span>
                      <% end %>
                    </td>
                    <td class="text-end">
                      <%= link_to backoffice_path(order), class: 'btn btn-outline-primary btn-sm rounded-pill px-3' do %>
                        Смотреть <i class="bi bi-binoculars-fill ms-1"></i>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <%# --- СЕКЦИЯ: ВЫПОЛНЕННЫЕ ЗАЯВКИ --- %>
      <section class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-secondary text-white p-3">
          <h2 class="h4 mb-0"><i class="bi bi-check2-all me-2"></i>Архив выполненных</h2>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
              <tbody class="text-muted">
                <% @completed_orders.each do |order| %>
                  <tr>
                    <td class="ps-3" style="width: 30%; font-weight: 500;"><%= order.desc %></td>
                    <td><%= order.service.title %></td>
                    <td><%= order.name %></td>
                    <td class="text-end pe-3">
                      <%= link_to backoffice_path(order), class: 'btn btn-link btn-sm text-decoration-none' do %>
                        Детали
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <div class="d-flex justify-content-center">
        <%= paginate @completed_orders %>
      </div>

    </div>

  </body>
</html>
